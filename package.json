{
  "name": "cargo-backend",
  "version": "1.0.0",
  "description": "CarGo automotive maintenance tracking backend",
  "main": "server.js",
  "scripts": {
    "start": "nodemon server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "db:migrate": "node db/migrate.js",
    "db:migrate:down": "node db/migrate-down.js",
    "db:migrate:create": "node db/migration-create.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.16.3",
    "pug": "^3.0.4"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ]
  }
}
