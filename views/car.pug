extends layout

block content
  .App.App--top
    main(style="padding: 40px 20px 20px;")
      .car-details-card
        h2= car.name
        dl.car-details-info
          div
            dt Make
            dd= car.make
          div
            dt Year
            dd= car.year
          div
            dt Model
            dd= car.model
          div
            dt Mileage
            dd= car.mileage.toLocaleString() + ' mi'

      .service-section
        ul#serviceTabs.nav.nav-tabs.mb-3(role="tablist")
          li.nav-item(role="presentation")
            button#scheduled-tab.nav-link.active(data-bs-toggle="tab", data-bs-target="#scheduled", type="button", role="tab", aria-controls="scheduled", aria-selected="true") Scheduled Service #[i.bi.bi-plus-square.scheduled-tab-icon]
          li.nav-item(role="presentation")
            button#history-tab.nav-link(data-bs-toggle="tab", data-bs-target="#history", type="button", role="tab", aria-controls="history", aria-selected="false") Service History #[i.bi.bi-plus-square.history-tab-icon]
          li.nav-item(role="presentation")
            button#mileage-tab.nav-link(data-bs-toggle="tab", data-bs-target="#mileage", type="button", role="tab", aria-controls="mileage", aria-selected="false") Mileage

        .tab-content#serviceTabsContent
          .tab-pane.fade.show.active#scheduled(role="tabpanel", aria-labelledby="scheduled-tab")
            if serviceItems.length === 0
              p No service items found for this car.
            else
              table.service-table
                thead
                  tr
                    th(style="width:2rem")
                    th Projected Date
                    th Title
                    th Description
                    th Mileage Interval
                    th Month Interval
                    th Specific Mileage
                    th Specific Date
                tbody
                  each item in serviceItems
                    tr.service-item-row(class=`urgency-${item.urgency}`
                      data-id=item.id
                      data-title=item.title
                      data-description=item.description || ''
                      data-mileage-interval=item.mileage_interval || ''
                      data-month-interval=item.month_interval || ''
                      data-specific-mileage=item.specific_mileage || ''
                      data-specific-date=item.specific_date ? new Date(item.specific_date).toISOString().split('T')[0] : ''
                    )
                      td.text-center
                        button.expand-toggle(type="button") ▶
                      td.text-center
                        if item.projected_date
                          if new Date(item.projected_date) > new Date(new Date().getTime() + 365 * 86400000)
                            | --
                          else
                            = new Date(item.projected_date).toLocaleDateString()
                        else
                          | N/A
                      td= item.title
                      td(class=item.description ? '' : 'text-center')= item.description || 'N/A'
                      td(class=item.mileage_interval ? '' : 'text-center')= item.mileage_interval ? item.mileage_interval.toLocaleString() + ' mi' : 'N/A'
                      td(class=item.month_interval ? '' : 'text-center')= item.month_interval ? item.month_interval + ' months' : 'N/A'
                      td(class=item.specific_mileage ? '' : 'text-center')= item.specific_mileage ? item.specific_mileage.toLocaleString() + ' mi' : 'N/A'
                      td(class=item.specific_date ? '' : 'text-center')= item.specific_date ? new Date(item.specific_date).toLocaleDateString() : 'N/A'

          .tab-pane.fade#history(role="tabpanel", aria-labelledby="history-tab")
            if serviceEvents.length === 0
              p No service history found for this car.
            table.service-table(style=serviceEvents.length === 0 ? 'display:none;' : '')
              colgroup
                col(style="width:16%")
                col(style="width:16%")
                col(style="width:20%")
                col(style="width:16%")
                col(style="width:32%")
              thead
                tr
                  th Date
                  th Mileage
                  th Description
                  th Performed By
                  th Notes
              tbody
                each event in serviceEvents
                  tr.service-event-row(
                    data-id=event.id
                    data-date=new Date(event.date).toISOString().split('T')[0]
                    data-mileage=event.mileage
                    data-performed-by=event.performed_by || ''
                    data-description=event.description || ''
                    data-notes=event.notes || ''
                    data-items=JSON.stringify(event.items)
                  )
                    td= new Date(event.date).toLocaleDateString()
                    td= event.mileage.toLocaleString() + ' mi'
                    td(class=(event.description) ? '' : 'text-center')= event.description || ''
                    td(class=(event.performed_by) ? '' : 'text-center')= event.performed_by || 'N/A'
                    td(class=(event.notes) ? '' : 'text-center')= event.notes || ''
                  each item in event.items
                    tr.service-event-item-row(data-event-id=event.id)
                      td(colspan="5")
                        span.event-item-bullet ▸
                        | &nbsp;
                        strong= item.service_item_title
                        if item.notes
                          = ': ' + item.notes

          .tab-pane.fade#mileage(role="tabpanel", aria-labelledby="mileage-tab")
            .chart-container(style="position: relative; height:40vh; width:100%")
              canvas#mileageChart

  //- Car Modal
  #carModal.modal.fade(tabindex="-1", aria-labelledby="carModalLabel", aria-hidden="true")
    .modal-dialog
      .modal-content
        .modal-header
          h5#carModalLabel.modal-title Edit Car
          button.btn-close(type="button", data-bs-dismiss="modal", aria-label="Close")
        .modal-body
          form#carForm
            .mb-3
              label.form-label(for="carName") Name
              input#carName.form-control(type="text", name="name", required)
            .row
              .col-md-6.mb-3
                label.form-label(for="carMake") Make
                input#carMake.form-control(type="text", name="make", required)
              .col-md-6.mb-3
                label.form-label(for="carModel") Model
                input#carModel.form-control(type="text", name="model", required)
            .row
              .col-md-6.mb-3
                label.form-label(for="carYear") Year
                input#carYear.form-control(type="number", name="year", required)
              .col-md-6.mb-3
                label.form-label(for="carMileage") Mileage
                input#carMileage.form-control(type="number", name="mileage", min="0", required)
        .modal-footer
          button#deleteCarBtn.btn.btn-danger.me-auto(type="button") Delete
          button.btn.btn-secondary(type="button", data-bs-dismiss="modal") Cancel
          button#carSaveBtn.btn.btn-primary(type="button") Save

  //- Service Item Modal
  #serviceItemModal.modal.fade(tabindex="-1", aria-labelledby="serviceItemModalLabel", aria-hidden="true")
    .modal-dialog.modal-lg
      .modal-content
        .modal-header
          h5#serviceItemModalLabel.modal-title Service Item
          button.btn-close(type="button", data-bs-dismiss="modal", aria-label="Close")
        .modal-body
          form#serviceItemForm
            input#serviceItemId(type="hidden", name="id")
            .mb-3
              label.form-label(for="serviceItemTitle") Title
              input#serviceItemTitle.form-control(type="text", name="title", required)
            .mb-3
              label.form-label(for="serviceItemDescription") Description
              textarea#serviceItemDescription.form-control(name="description", rows="3")
            .row
              .col-md-6.mb-3
                label.form-label(for="serviceItemMileageInterval") Mileage Interval
                input#serviceItemMileageInterval.form-control(type="number", name="mileage_interval", min="0")
              .col-md-6.mb-3
                label.form-label(for="serviceItemMonthInterval") Month Interval
                input#serviceItemMonthInterval.form-control(type="number", name="month_interval", min="0")
            .row
              .col-md-6.mb-3
                label.form-label(for="serviceItemSpecificMileage") Specific Mileage
                input#serviceItemSpecificMileage.form-control(type="number", name="specific_mileage", min="0")
              .col-md-6.mb-3
                label.form-label(for="serviceItemSpecificDate") Specific Date
                input#serviceItemSpecificDate.form-control(type="date", name="specific_date")
        .modal-footer
          button#deleteItemBtn.btn.btn-danger.me-auto(type="button", style="display:none;") Delete
          button.btn.btn-secondary(type="button", data-bs-dismiss="modal") Cancel
          button.btn.btn-primary(type="button") Save

  //- Service Event Modal
  #serviceEventModal.modal.fade(tabindex="-1", aria-labelledby="serviceEventModalLabel", aria-hidden="true")
    .modal-dialog.modal-lg
      .modal-content
        .modal-header
          h5#serviceEventModalLabel.modal-title Service Event
          button.btn-close(type="button", data-bs-dismiss="modal", aria-label="Close")
        .modal-body
          form#serviceEventForm
            input#serviceEventId(type="hidden", name="id")
            .row
              .col-md-6.mb-3
                label.form-label(for="serviceEventDate") Date
                input#serviceEventDate.form-control(type="date", name="date", required)
              .col-md-6.mb-3
                label.form-label(for="serviceEventMileage") Mileage
                input#serviceEventMileage.form-control(type="number", name="mileage", min="0", required)
            .mb-3
              label.form-label(for="serviceEventPerformedBy") Performed By
              input#serviceEventPerformedBy.form-control(type="text", name="performed_by")
            .mb-3
              label.form-label(for="serviceEventDescription") Description
              input#serviceEventDescription.form-control(type="text", name="description")
            .mb-3
              label.form-label(for="serviceEventNotes") Notes
              textarea#serviceEventNotes.form-control(name="notes", rows="2")
            .mb-3
              label.form-label Service Items
              #eventItemsList
              button#addEventItemBtn.btn.btn-outline-secondary.btn-sm.mt-2(type="button")
                i.bi.bi-plus-square
                |  Add Item
        .modal-footer
          button#deleteEventBtn.btn.btn-danger.me-auto(type="button", style="display:none;") Delete
          button.btn.btn-secondary(type="button", data-bs-dismiss="modal") Cancel
          button#eventSaveBtn.btn.btn-primary(type="button") Save

  script.
    const CAR_ID = !{car.id};
    const orNull = v => v === '' ? null : v;
    let allServiceEvents = !{JSON.stringify(serviceEvents)};
    let allServiceItems = !{JSON.stringify(allServiceItems)};
    let carMileage = !{car.mileage};

    // ── Service Items ────────────────────────────────────────────────

    let currentItemRow = null;
    let itemCreatedFromEventModal = false;
    let newItemTargetSelect = null;

    document.getElementById('serviceItemModal').addEventListener('hidden.bs.modal', () => {
      if (itemCreatedFromEventModal) {
        itemCreatedFromEventModal = false;
        newItemTargetSelect = null;
        bootstrap.Modal.getOrCreateInstance(document.getElementById('serviceEventModal')).show();
      }
    });

    function populateItemRowFromData(row, item) {
      row.dataset.id = item.id;
      row.dataset.title = item.title;
      row.dataset.description = item.description || '';
      row.dataset.mileageInterval = item.mileage_interval || '';
      row.dataset.monthInterval = item.month_interval || '';
      row.dataset.specificMileage = item.specific_mileage || '';
      row.dataset.specificDate = item.specific_date ? new Date(item.specific_date).toISOString().split('T')[0] : '';
      const cells = row.querySelectorAll('td');
      // cells[0] is expand toggle — skip
      // cells[1] is Projected Date — leave it as-is (set by server or left as N/A for new items)
      cells[2].textContent = item.title;
      cells[3].className = item.description ? '' : 'text-center';
      cells[3].textContent = item.description || 'N/A';
      cells[4].className = item.mileage_interval ? '' : 'text-center';
      cells[4].textContent = item.mileage_interval ? Number(item.mileage_interval).toLocaleString() + ' mi' : 'N/A';
      cells[5].className = item.month_interval ? '' : 'text-center';
      cells[5].textContent = item.month_interval ? item.month_interval + ' months' : 'N/A';
      cells[6].className = item.specific_mileage ? '' : 'text-center';
      cells[6].textContent = item.specific_mileage ? Number(item.specific_mileage).toLocaleString() + ' mi' : 'N/A';
      cells[7].className = item.specific_date ? '' : 'text-center';
      cells[7].textContent = item.specific_date ? new Date(item.specific_date).toLocaleDateString() : 'N/A';
    }

    function makeItemRow(item) {
      const row = document.createElement('tr');
      row.className = 'service-item-row';
      row.innerHTML = '<td class="text-center"><button class="expand-toggle" type="button">▶</button></td><td class="text-center">N/A</td><td></td><td></td><td></td><td></td><td></td><td></td>';
      populateItemRowFromData(row, item);
      attachItemRowHandler(row);
      return row;
    }

    function openItemModal(title, rowOrNull) {
      currentItemRow = rowOrNull;
      document.getElementById('serviceItemModalLabel').textContent = title;
      document.getElementById('serviceItemForm').reset();
      document.getElementById('serviceItemId').value = '';
      document.getElementById('deleteItemBtn').style.display = rowOrNull ? '' : 'none';
      if (rowOrNull) {
        const d = rowOrNull.dataset;
        document.getElementById('serviceItemId').value = d.id;
        document.getElementById('serviceItemTitle').value = d.title;
        document.getElementById('serviceItemDescription').value = d.description;
        document.getElementById('serviceItemMileageInterval').value = d.mileageInterval;
        document.getElementById('serviceItemMonthInterval').value = d.monthInterval;
        document.getElementById('serviceItemSpecificMileage').value = d.specificMileage;
        document.getElementById('serviceItemSpecificDate').value = d.specificDate;
      }
      bootstrap.Modal.getOrCreateInstance(document.getElementById('serviceItemModal')).show();
    }

    function attachItemRowHandler(row) {
      row.addEventListener('dblclick', () => openItemModal('Edit Service Item', row));
      attachExpandToggle(row);
    }

    function attachExpandToggle(row) {
      const btn = row.querySelector('.expand-toggle');
      if (!btn) return;
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const itemId = parseInt(row.dataset.id);
        const existing = document.querySelector(`.service-item-history-row[data-item-id="${itemId}"]`);
        if (existing) {
          document.querySelectorAll(`.service-item-history-row[data-item-id="${itemId}"]`).forEach(r => r.remove());
          btn.textContent = '▶';
          return;
        }
        btn.textContent = '▼';
        const matchingEvents = allServiceEvents.filter(ev =>
          ev.items.some(i => i.service_item_id === itemId)
        );
        row.insertAdjacentElement('afterend', makeItemHistoryRow(itemId, matchingEvents));
      });
    }

    function collapseAllItemHistory() {
      document.querySelectorAll('.service-item-history-row').forEach(r => r.remove());
      document.querySelectorAll('#scheduled .expand-toggle').forEach(btn => { btn.textContent = '▶'; });
    }

    function makeItemHistoryRow(itemId, events) {
      const tr = document.createElement('tr');
      tr.className = 'service-item-history-row';
      tr.dataset.itemId = String(itemId);
      const td = document.createElement('td');
      td.colSpan = 8;
      if (events.length === 0) {
        td.className = 'service-item-history-empty text-center';
        td.textContent = 'No history recorded for this service item.';
        tr.appendChild(td);
        return tr;
      }
      const table = document.createElement('table');
      table.className = 'item-history-subtable';
      const thead = document.createElement('thead');
      thead.innerHTML = '<tr><th>Date</th><th>Mileage</th><th>Performed By</th><th>Notes</th></tr>';
      const tbody = document.createElement('tbody');
      const sorted = [...events].sort((a, b) => new Date(b.date) - new Date(a.date));
      for (const event of sorted) {
        const itemEntry = event.items.find(i => i.service_item_id === itemId);
        const eRow = document.createElement('tr');
        eRow.innerHTML =
          '<td>' + new Date(event.date).toLocaleDateString() + '</td>' +
          '<td>' + Number(event.mileage).toLocaleString() + ' mi</td>' +
          '<td>' + escapeHtml(event.performed_by || 'N/A') + '</td>' +
          '<td>' + (itemEntry && itemEntry.notes ? escapeHtml(itemEntry.notes) : '') + '</td>';
        tbody.appendChild(eRow);
      }
      table.appendChild(thead);
      table.appendChild(tbody);
      td.appendChild(table);
      tr.appendChild(td);
      return tr;
    }

    document.querySelectorAll('.service-item-row').forEach(attachItemRowHandler);

    document.getElementById('deleteItemBtn').addEventListener('click', async () => {
      const id = document.getElementById('serviceItemId').value;
      if (!confirm('Delete this service item and all its history? This cannot be undone.')) return;
      try {
        const res = await fetch(`/api/service-items/${id}`, { method: 'DELETE' });
        if (!res.ok) throw new Error(await res.text());
        currentItemRow.remove();
        bootstrap.Modal.getInstance(document.getElementById('serviceItemModal')).hide();
      } catch (err) {
        alert('Failed to delete: ' + err.message);
      }
    });

    document.querySelector('.scheduled-tab-icon').addEventListener('click', e => {
      e.stopPropagation();
      openItemModal('New Service Item', null);
    });

    document.querySelector('#serviceItemModal .btn-primary').addEventListener('click', async () => {
      const id = document.getElementById('serviceItemId').value;
      const body = {
        title: document.getElementById('serviceItemTitle').value,
        description: orNull(document.getElementById('serviceItemDescription').value),
        mileage_interval: orNull(document.getElementById('serviceItemMileageInterval').value),
        month_interval: orNull(document.getElementById('serviceItemMonthInterval').value),
        specific_mileage: orNull(document.getElementById('serviceItemSpecificMileage').value),
        specific_date: orNull(document.getElementById('serviceItemSpecificDate').value),
      };
      try {
        let item;
        if (id) {
          const res = await fetch(`/api/service-items/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          if (!res.ok) throw new Error(await res.text());
          item = await res.json();
          populateItemRowFromData(currentItemRow, item);
        } else {
          const res = await fetch('/api/service-items', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ...body, car_id: CAR_ID }),
          });
          if (!res.ok) throw new Error(await res.text());
          item = await res.json();
          allServiceItems.push(item);
          // Add to scheduled service table
          const scheduledTbody = document.querySelector('#scheduled .service-table tbody');
          if (scheduledTbody) scheduledTbody.appendChild(makeItemRow(item));
          // If triggered from event modal, update all event item selects
          if (itemCreatedFromEventModal) {
            document.querySelectorAll('#eventItemsList select').forEach(sel => {
              const opt = document.createElement('option');
              opt.value = item.id;
              opt.textContent = item.title;
              sel.appendChild(opt);
            });
            if (newItemTargetSelect) {
              newItemTargetSelect.value = item.id;
              newItemTargetSelect = null;
            }
          }
        }
        const reopenEventModal = itemCreatedFromEventModal;
        itemCreatedFromEventModal = false;
        bootstrap.Modal.getInstance(document.getElementById('serviceItemModal')).hide();
        if (reopenEventModal) {
          bootstrap.Modal.getOrCreateInstance(document.getElementById('serviceEventModal')).show();
        }
      } catch (err) {
        alert('Failed to save: ' + err.message);
      }
    });

    // ── Service Events ───────────────────────────────────────────────

    let currentEventRow = null;

    const ADD_NEW_SENTINEL = '__add_new__';

    function buildItemSelect(serviceItemId) {
      const select = document.createElement('select');
      select.className = 'form-select';
      const placeholder = document.createElement('option');
      placeholder.value = '';
      placeholder.textContent = '';
      placeholder.disabled = true;
      select.appendChild(placeholder);
      const addNewOpt = document.createElement('option');
      addNewOpt.value = ADD_NEW_SENTINEL;
      addNewOpt.textContent = '+ Add new service item';
      select.appendChild(addNewOpt);
      for (const si of allServiceItems) {
        const opt = document.createElement('option');
        opt.value = si.id;
        opt.textContent = si.title;
        select.appendChild(opt);
      }
      select.value = serviceItemId != null ? serviceItemId : '';
      select.addEventListener('change', () => {
        if (select.value === ADD_NEW_SENTINEL) {
          select.selectedIndex = 0;
          newItemTargetSelect = select;
          itemCreatedFromEventModal = true;
          bootstrap.Modal.getInstance(document.getElementById('serviceEventModal')).hide();
          openItemModal('New Service Item', null);
        }
      });
      return select;
    }

    function addEventItemRow(serviceItemId, notes) {
      const row = document.createElement('div');
      row.className = 'event-item-row d-flex gap-2 mb-2 align-items-center';

      const select = buildItemSelect(serviceItemId);

      const notesInput = document.createElement('input');
      notesInput.type = 'text';
      notesInput.className = 'form-control';
      notesInput.placeholder = 'Notes for this item';
      notesInput.value = notes || '';

      const removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.className = 'btn btn-outline-danger flex-shrink-0';
      removeBtn.textContent = '×';
      removeBtn.addEventListener('click', () => {
        const list = document.getElementById('eventItemsList');
        if (list.children.length > 1) row.remove();
      });

      row.appendChild(select);
      row.appendChild(notesInput);
      row.appendChild(removeBtn);
      document.getElementById('eventItemsList').appendChild(row);
      return select;
    }

    function populateEventRowFromData(row, event) {
      row.dataset.id = event.id;
      row.dataset.date = new Date(event.date).toISOString().split('T')[0];
      row.dataset.mileage = event.mileage;
      row.dataset.performedBy = event.performed_by || '';
      row.dataset.description = event.description || '';
      row.dataset.notes = event.notes || '';
      row.dataset.items = JSON.stringify(event.items);
      const cells = row.querySelectorAll('td');
      cells[0].textContent = new Date(event.date).toLocaleDateString();
      cells[1].textContent = Number(event.mileage).toLocaleString() + ' mi';
      cells[2].className = event.description ? '' : 'text-center';
      cells[2].textContent = event.description || '';
      cells[3].className = event.performed_by ? '' : 'text-center';
      cells[3].textContent = event.performed_by || 'N/A';
      cells[4].className = event.notes ? '' : 'text-center';
      cells[4].textContent = event.notes || '';
    }

    function makeEventRow(event) {
      const row = document.createElement('tr');
      row.className = 'service-event-row';
      row.innerHTML = '<td></td><td></td><td></td><td></td><td></td>';
      populateEventRowFromData(row, event);
      attachEventRowHandler(row);
      return row;
    }

    function makeItemSubRow(item, eventId) {
      const row = document.createElement('tr');
      row.className = 'service-event-item-row';
      row.dataset.eventId = eventId;
      const td = document.createElement('td');
      td.colSpan = 5;
      td.innerHTML = '<span class="event-item-bullet">▸</span>&nbsp;<strong>' +
        escapeHtml(item.service_item_title) + '</strong>' +
        (item.notes ? ': ' + escapeHtml(item.notes) : '');
      row.appendChild(td);
      return row;
    }

    function escapeHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function openEventModal(title, rowOrNull) {
      currentEventRow = rowOrNull;
      document.getElementById('serviceEventModalLabel').textContent = title;
      document.getElementById('serviceEventForm').reset();
      document.getElementById('serviceEventId').value = '';
      document.getElementById('deleteEventBtn').style.display = rowOrNull ? '' : 'none';
      document.getElementById('eventItemsList').innerHTML = '';

      if (!rowOrNull) {
        document.getElementById('serviceEventDate').value = new Date().toISOString().split('T')[0];
        addEventItemRow();
      } else {
        const d = rowOrNull.dataset;
        document.getElementById('serviceEventId').value = d.id;
        document.getElementById('serviceEventDate').value = d.date;
        document.getElementById('serviceEventMileage').value = d.mileage;
        document.getElementById('serviceEventPerformedBy').value = d.performedBy;
        document.getElementById('serviceEventDescription').value = d.description;
        document.getElementById('serviceEventNotes').value = d.notes;
        const items = JSON.parse(d.items || '[]');
        if (items.length === 0) {
          addEventItemRow();
        } else {
          for (const item of items) {
            addEventItemRow(item.service_item_id, item.notes || '');
          }
        }
      }
      bootstrap.Modal.getOrCreateInstance(document.getElementById('serviceEventModal')).show();
    }

    function attachEventRowHandler(row) {
      row.addEventListener('dblclick', () => openEventModal('Edit Service Event', row));
    }

    document.querySelectorAll('.service-event-row').forEach(attachEventRowHandler);

    document.getElementById('deleteEventBtn').addEventListener('click', async () => {
      const id = document.getElementById('serviceEventId').value;
      if (!confirm('Delete this service event? This cannot be undone.')) return;
      try {
        const res = await fetch(`/api/service-events/${id}`, { method: 'DELETE' });
        if (!res.ok) throw new Error(await res.text());
        currentEventRow.remove();
        document.querySelectorAll(`.service-event-item-row[data-event-id="${id}"]`).forEach(r => r.remove());
        allServiceEvents = allServiceEvents.filter(e => e.id != id);
        updateMileageChart();
        bootstrap.Modal.getInstance(document.getElementById('serviceEventModal')).hide();
      } catch (err) {
        alert('Failed to delete: ' + err.message);
      }
    });

    document.querySelector('.history-tab-icon').addEventListener('click', e => {
      e.stopPropagation();
      openEventModal('New Service Event', null);
    });

    document.getElementById('addEventItemBtn').addEventListener('click', () => {
      addEventItemRow();
    });

    document.getElementById('eventSaveBtn').addEventListener('click', async () => {
      const id = document.getElementById('serviceEventId').value;
      const itemRows = document.querySelectorAll('#eventItemsList .event-item-row');
      const items = Array.from(itemRows).map(row => ({
        service_item_id: parseInt(row.querySelector('select').value),
        notes: orNull(row.querySelector('input[type="text"]').value),
      }));
      const body = {
        car_id: CAR_ID,
        date: document.getElementById('serviceEventDate').value,
        mileage: parseInt(document.getElementById('serviceEventMileage').value),
        performed_by: orNull(document.getElementById('serviceEventPerformedBy').value),
        description: orNull(document.getElementById('serviceEventDescription').value),
        notes: orNull(document.getElementById('serviceEventNotes').value),
        items,
      };
      try {
        let event;
        if (id) {
          const res = await fetch(`/api/service-events/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          if (!res.ok) throw new Error(await res.text());
          event = await res.json();
          populateEventRowFromData(currentEventRow, event);
          document.querySelectorAll(`.service-event-item-row[data-event-id="${event.id}"]`).forEach(r => r.remove());
          let anchor = currentEventRow;
          for (const item of event.items) {
            const itemRow = makeItemSubRow(item, event.id);
            anchor.insertAdjacentElement('afterend', itemRow);
            anchor = itemRow;
          }
          const idx = allServiceEvents.findIndex(e => e.id === event.id);
          if (idx !== -1) allServiceEvents[idx] = event;
        } else {
          const res = await fetch('/api/service-events', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          if (!res.ok) throw new Error(await res.text());
          event = await res.json();
          // Show history table if it was hidden (no prior events)
          const historyTable = document.querySelector('#history .service-table');
          const emptyMsg = document.querySelector('#history p');
          if (historyTable) historyTable.style.display = '';
          if (emptyMsg) emptyMsg.style.display = 'none';
          const tbody = document.querySelector('#history .service-table tbody');
          const eventRow = makeEventRow(event);
          tbody.prepend(eventRow);
          let anchor = eventRow;
          for (const item of event.items) {
            const itemRow = makeItemSubRow(item, event.id);
            anchor.insertAdjacentElement('afterend', itemRow);
            anchor = itemRow;
          }
          allServiceEvents.unshift(event);
        }
        if (event.mileage > carMileage) {
          carMileage = event.mileage;
          const mileageDd = document.querySelectorAll('.car-details-info dd')[3];
          if (mileageDd) mileageDd.textContent = Number(carMileage).toLocaleString() + ' mi';
        }
        updateMileageChart();
        collapseAllItemHistory();
        bootstrap.Modal.getInstance(document.getElementById('serviceEventModal')).hide();
      } catch (err) {
        alert('Failed to save: ' + err.message);
      }
    });

    // ── Mileage Chart ────────────────────────────────────────────────
    let mileageChart = null;

    function updateMileageChart() {
      if (!mileageChart) return;

      const dataPoints = allServiceEvents.map(e => ({
        x: new Date(e.date).toISOString().split('T')[0],
        y: e.mileage
      }));
      dataPoints.push({
        x: new Date().toISOString().split('T')[0],
        y: carMileage
      });
      const sortedPoints = dataPoints.sort((a, b) => a.x.localeCompare(b.x));
      const filteredPoints = [];
      for (const p of sortedPoints) {
        if (filteredPoints.length > 0 && filteredPoints[filteredPoints.length - 1].x === p.x) {
          filteredPoints[filteredPoints.length - 1].y = Math.max(filteredPoints[filteredPoints.length - 1].y, p.y);
        } else {
          filteredPoints.push(p);
        }
      }
      mileageChart.data.datasets[0].data = filteredPoints;
      mileageChart.update();
    }

    const mileageTab = document.getElementById('mileage-tab');
    if (mileageTab) {
      mileageTab.addEventListener('shown.bs.tab', () => {
        if (mileageChart) return;

        const ctx = document.getElementById('mileageChart').getContext('2d');
        const dataPoints = allServiceEvents.map(e => ({
          x: new Date(e.date).toISOString().split('T')[0],
          y: e.mileage
        }));
        dataPoints.push({
          x: new Date().toISOString().split('T')[0],
          y: carMileage
        });
        const sortedPoints = dataPoints.sort((a, b) => a.x.localeCompare(b.x));
        const filteredPoints = [];
        for (const p of sortedPoints) {
          if (filteredPoints.length > 0 && filteredPoints[filteredPoints.length - 1].x === p.x) {
            filteredPoints[filteredPoints.length - 1].y = Math.max(filteredPoints[filteredPoints.length - 1].y, p.y);
          } else {
            filteredPoints.push(p);
          }
        }

        mileageChart = new Chart(ctx, {
          type: 'line',
          data: {
            datasets: [{
              label: 'Car Mileage',
              data: filteredPoints,
              borderColor: '#ffd700',
              backgroundColor: 'rgba(255, 215, 0, 0.2)',
              fill: true,
              tension: 0.1
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
              x: {
                type: 'time',
                time: {
                  unit: 'month',
                  displayFormats: {
                    month: 'MMM yyyy'
                  }
                },
                title: {
                  display: true,
                  text: 'Date',
                  color: '#ffffff'
                },
                ticks: {
                  color: '#ffffff'
                },
                grid: {
                  color: 'rgba(255, 255, 255, 0.1)'
                }
              },
              y: {
                title: {
                  display: true,
                  text: 'Mileage (mi)',
                  color: '#ffffff'
                },
                ticks: {
                  color: '#ffffff'
                },
                grid: {
                  color: 'rgba(255, 255, 255, 0.1)'
                },
                beginAtZero: false
              }
            },
            plugins: {
              legend: {
                labels: {
                  color: '#ffffff'
                }
              }
            }
          }
        });
      });
    }

    // ── Car Details ──────────────────────────────────────────────────

    document.querySelector('.car-details-card').addEventListener('dblclick', () => {
      document.getElementById('carName').value = '!{car.name}';
      document.getElementById('carMake').value = '!{car.make}';
      document.getElementById('carModel').value = '!{car.model}';
      document.getElementById('carYear').value = !{car.year};
      document.getElementById('carMileage').value = !{car.mileage};
      bootstrap.Modal.getOrCreateInstance(document.getElementById('carModal')).show();
    });

    document.getElementById('deleteCarBtn').addEventListener('click', async () => {
      if (!confirm('Delete this car and all its service data? This cannot be undone.')) return;
      try {
        const res = await fetch(`/api/cars/${CAR_ID}`, { method: 'DELETE' });
        if (!res.ok) throw new Error(await res.text());
        window.location.href = '/';
      } catch (err) {
        alert('Failed to delete: ' + err.message);
      }
    });

    document.getElementById('carSaveBtn').addEventListener('click', async () => {
      const body = {
        name: document.getElementById('carName').value,
        make: document.getElementById('carMake').value,
        model: document.getElementById('carModel').value,
        year: document.getElementById('carYear').value,
        mileage: document.getElementById('carMileage').value,
      };
      try {
        const res = await fetch(`/api/cars/${CAR_ID}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (!res.ok) throw new Error(await res.text());
        const car = await res.json();
        carMileage = car.mileage;
        updateMileageChart();
        document.querySelector('.car-details-card h2').textContent = car.name;
        const dds = document.querySelectorAll('.car-details-info dd');
        dds[0].textContent = car.make;
        dds[1].textContent = car.year;
        dds[2].textContent = car.model;
        dds[3].textContent = Number(car.mileage).toLocaleString() + ' mi';
        bootstrap.Modal.getInstance(document.getElementById('carModal')).hide();
      } catch (err) {
        alert('Failed to save: ' + err.message);
      }
    });
